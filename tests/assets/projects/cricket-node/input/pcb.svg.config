//   D16: two-pin, side=top, pads=A,C, cathode=C, reason=designator+text:led
//   Q1: multi-pin, side=top, pads=1,2,3, cathode=numeric-default, reason=text:diode
//   Q2: multi-pin, side=top, pads=1,2,3, cathode=numeric-default, reason=text:diode
//   Q6: multi-pin, side=top, pads=1,2,3,4, cathode=numeric-default, reason=text:diode
//   Q7: multi-pin, side=top, pads=1,2,3, cathode=numeric-default, reason=text:diode
//   U1: multi-pin, side=top, pads=1,2,3,4,5, cathode=numeric-default, reason=text:diode
//   U7: multi-pin, side=top, pads=1,2,3,4,5,6,7,8,9, cathode=numeric-default, reason=text:diode
//   U8: multi-pin, side=top, pads=1,2,3,4,5, cathode=numeric-default, reason=text:diode
//   U11: multi-pin, side=top, pads=1,2,3,4,5, cathode=numeric-default, reason=text:diode
//   U15: multi-pin, side=top, pads=1,2,3,4, cathode=numeric-default, reason=text:tvs

// Set layer_outputs.enabled=false if you only want composed views.
{
  "schema": "pcb.svg.config.a0",
  "global": {
    "canvas": {
      "bounds": "board_outline",
      "margin_mm": 1.0
    },
    "include_metadata": true,
    "show_empty_layers": false,
    "clip_to_outline": true,
    "clip_holes_from_copper": true,
    "mirror_bottom_view": true,
    "svg_scale": 10.0,
    "svg_size_unit": "",
    "clean_output": false,
    "styles": {
      "board_outline": {
        "enabled": true,
        "color": "#000000",
        "line_width_mm": 0.1
      },
      "board_cutouts": {
        "enabled": true,
        "color": "#FF0000",
        "hatch": true,
        "hatch_spacing_mm": 2.0,
        "hatch_angle_deg": 45.0,
        "hatch_line_width_mm": 0.08,
        "outline_style": "solid",
        "outline_dash_mm": 1.5,
        "outline_width_mm": 0.15
      },
      "drills": {
        "enabled": true,
        "plated_color": "#90EE90",
        "non_plated_color": "#ADD8E6",
        "opacity": 1.0
      },
      "slots": {
        "enabled": true,
        "plated_color": "#90EE90",
        "non_plated_color": "#ADD8E6",
        "opacity": 1.0
      },
      "copper_traces": {
        "enabled": true,
        "color": "#000000"
      },
      "vias": {
        "enabled": true,
        "color": "#000000"
      },
      "copper_polygons": {
        "enabled": true,
        "color": "#888888"
      },
      "smd_pads": {
        "enabled": true,
        "color": "#000000"
      },
      "through_hole_pads": {
        "enabled": true,
        "color": "#000000"
      },
      "silkscreen_component_graphics": {
        "enabled": true,
        "color": "#000000"
      },
      "silkscreen_designators": {
        "enabled": true,
        "color": "#000000"
      },
      "silkscreen_board_graphics": {
        "enabled": true,
        "color": "#000000"
      },
      "pin1_marker": {
        "enabled": true,
        "color": "#2563EB",
        "dot_diameter_mm": 0.55,
        "min_dot_diameter_mm": 0.25
      },
      "keepout": {
        "enabled": true,
        "color": "#CC00CC"
      },
      "assembly_hlr": {
        "enabled": true,
        "color": "#F59E0B",
        "line_width_mm": 0.12,
        "curve_mode": "native_arcs",
        "samples_per_curve": 24,
        "round_digits": 3,
        "include_visible": true,
        "include_outline": true,
        "union_polygons": true
      }
    }
  },
  "pin1": {
    "exclude_designator_prefixes": [
      "R",
      "C",
      "L"
    ]
  },
  "layer_outputs": {
    "enabled": true,
    "layers": "auto",
    "include_special_layers": [
      "BOARD_OUTLINE",
      "BOARD_CUTOUTS",
      "DRILLS",
      "SLOTS"
    ],
    "output_dir": "layers"
  },
  "views": [
    {
      "name": "top_view",
      "enabled": true,
      "group_id": "pcb-svg-view-top",
      "output_svg": "views/{board}__top_view.svg",
      "layers": [
        "BOARD_OUTLINE",
        "TOP",
        "TOPOVERLAY",
        "BOARD_CUTOUTS",
        "DRILLS",
        "SLOTS",
        "ASSEMBLY_HLR_TOP"
      ],
      "assembly_hlr_mode": "detail",
      "mirror": false,
      "description": "Top view"
    },
    {
      "name": "bottom_view",
      "enabled": true,
      "group_id": "pcb-svg-view-bottom",
      "output_svg": "views/{board}__bottom_view.svg",
      "layers": [
        "BOARD_OUTLINE",
        "BOTTOM",
        "BOTTOMOVERLAY",
        "BOARD_CUTOUTS",
        "DRILLS",
        "SLOTS",
        "ASSEMBLY_HLR_BOTTOM"
      ],
      "assembly_hlr_mode": "detail",
      "mirror": true,
      "description": "Bottom view"
    },
    {
      "name": "board_cutouts",
      "enabled": true,
      "group_id": "pcb-svg-view-board-cutouts",
      "output_svg": "views/{board}__board_cutouts.svg",
      "layers": [
        "BOARD_OUTLINE",
        "BOARD_CUTOUTS"
      ],
      "assembly_hlr_mode": "detail",
      "mirror": false,
      "description": "Board cutouts"
    },
    {
      "name": "top_hlr_bounding_boxes",
      "enabled": true,
      "group_id": "pcb-svg-view-top-hlr-bounding-boxes",
      "output_svg": "views/{board}__top_hlr_bounding_boxes.svg",
      "layers": [
        "BOARD_OUTLINE",
        "TOP",
        "ASSEMBLY_HLR_TOP"
      ],
      "assembly_hlr_mode": "bounding_box",
      "mirror": false,
      "description": "Top copper with HLR pad bounding boxes"
    },
    {
      "name": "bottom_hlr_bounding_boxes",
      "enabled": true,
      "group_id": "pcb-svg-view-bottom-hlr-bounding-boxes",
      "output_svg": "views/{board}__bottom_hlr_bounding_boxes.svg",
      "layers": [
        "BOARD_OUTLINE",
        "BOTTOM",
        "ASSEMBLY_HLR_BOTTOM"
      ],
      "assembly_hlr_mode": "bounding_box",
      "mirror": true,
      "description": "Bottom copper with HLR pad bounding boxes"
    },
    {
      "name": "top_pin1_view",
      "enabled": true,
      "group_id": "pcb-svg-view-top-pin1",
      "output_svg": "views/{board}__top_pin1_view.svg",
      "layers": [
        "BOARD_OUTLINE",
        "TOP",
        "DRILLS",
        "SLOTS",
        "PIN1_TOP",
        "ASSEMBLY_HLR_TOP"
      ],
      "assembly_hlr_mode": "simple",
      "mirror": false,
      "description": "Top copper with pin-1 overlay"
    },
    {
      "name": "bottom_pin1_view",
      "enabled": true,
      "group_id": "pcb-svg-view-bottom-pin1",
      "output_svg": "views/{board}__bottom_pin1_view.svg",
      "layers": [
        "BOARD_OUTLINE",
        "BOTTOM",
        "DRILLS",
        "SLOTS",
        "PIN1_BOTTOM",
        "ASSEMBLY_HLR_BOTTOM"
      ],
      "assembly_hlr_mode": "simple",
      "mirror": true,
      "description": "Bottom copper with pin-1 overlay"
    }
  ]
}
